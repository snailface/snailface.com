# Cloudflare Pages headers.
# Static assets are requested with version query strings (e.g. style.css?v=4),
# so they can be cached aggressively and "busted" by bumping the version.

# Long-lived immutable caching for fingerprinted / rarely-changing assets.
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=604800

# HTML should always be revalidated so deploys show up immediately.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
